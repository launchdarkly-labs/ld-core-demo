### LaunchDarkly
LD_API_KEY=your-api-key-here
# SDK key and client-side ID are set when the user connects to a project in the app (user menu). No env fallback.

# Project key for admin actions (e.g. Create AI configs). Defaults to nteixeira-ld-demo if unset.
# LD_PROJECT_KEY=nteixeira-ld-demo

### LLM fallbacks (when not set via LaunchDarkly AI Config)
LLM_PROVIDER=bedrock
LLM_MODEL=claude-3-5-sonnet

# Toxicity score above this triggers resend with guardrails. Override with env TOXICITY_THRESHOLD (0–1).
TOXICITY_THRESHOLD=0.5

### AWS (Bedrock)
AWS_DEFAULT_REGION=us-east-1
### Local only: SSO profile (aws sso login --profile aiconfigdemo). Omit in Docker/EKS so SDK uses pod/instance role.
AWS_PROFILE=aiconfigdemo

### Optional: LaunchDarkly Observability (sessions, traces, errors)
# Observability is on whenever the LD SDK is used. Server sends traces to LaunchDarkly by default.
# LD_OBSERVABILITY_SERVICE_NAME=multi-agent-node   # service name in traces (default: multi-agent-node)
# LD_OTLP_ENDPOINT=                                # override OTLP endpoint (default: LaunchDarkly)
# LD_SESSION_REPLAY_PRIVACY=                       # default | strict (client-side replay after Connect)


PORT=3000
