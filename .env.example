# LaunchDarkly
# Client-side ID for browser Observability + Session Replay (from Project → Environments → SDK key)
# LD_CLIENT_ID=your-client-side-id
LD_SDK_KEY=sdk-your-key-here
# Optional: observability – service name in traces (server + frontend); omit to use default
# LD_OBSERVABILITY_SERVICE_NAME=policy-agent-node
# LD_OTLP_ENDPOINT=https://otel.observability.app.launchdarkly.com

# LLM fallbacks (when not set via LaunchDarkly AI Config)
LLM_PROVIDER=bedrock
LLM_MODEL=claude-3-5-sonnet

# AWS (Bedrock)
AWS_REGION=us-east-1
# Local only: SSO profile (aws sso login --profile aiconfigdemo). Omit in Docker/EKS so SDK uses pod/instance role.
AWS_PROFILE=aiconfigdemo

# Bedrock Knowledge Base IDs (or set via LaunchDarkly AI Config custom params)
BEDROCK_POLICY_KB_ID=
BEDROCK_PROVIDER_KB_ID=

# Optional
OPENAI_API_KEY=

PORT=3000
